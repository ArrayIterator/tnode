{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Tray Node Theme Schema",
    "description": "Schema for theme.json settings file for theme based on Handlebars.",
    "type": "object",
    "required": [
        "name",
        "version",
        "author",
        "directories"
    ],
    "definitions": {
        "template_file": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_-]+(\/[a-zA-Z0-9_-]+)*$"
        }
    },
    "properties": {
        "name": {
            "type": "string",
            "description": "The display name of your theme.",
            "minLength": 1
        },
        "description": {
            "type": "string",
            "description": "A short description of your theme."
        },
        "url": {
            "type": "string",
            "format": "uri",
            "description": "A URL to the homepage of your theme."
        },
        "screenshot": {
            "description": "A screenshot of your theme.",
            "oneOf": [
                {
                    "type": "string",
                    "pattern": "https?://.+\\.(?:png|jpg|jpeg|webp|gif)(\\?.*)?(#[a-zA-Z0-9]+)?$",
                    "description": "A screenshot of your theme."
                },
                {
                    "type": "string",
                    "pattern": "^[a-zA-Z0-9_-]+(\/[a-zA-Z0-9_-]+)*\\.(png|jpg|jpeg|webp|gif)$",
                    "description": "A screenshot path your theme."
                }
            ]
        },
        "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$",
            "description": "Semantic versioning (e.g., 1.0.0)."
        },
        "author": {
            "type": "object",
            "required": ["name"],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Name of the theme author."
                },
                "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email address of the theme author."
                },
                "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL to the theme author's website."
                }
            }
        },
        "directories": {
            "type": "object",
            "description": "The directories of the theme. Additional names can be added and will be pointed as includes.",
            "required": ["assets"],
            "additionalProperties": false,
            "properties": {
                "language": {
                    "type": "string",
                    "pattern": "^[a-zA-Z0-9_]+(\/[a-zA-Z0-9_]+)?$",
                    "default": "languages",
                    "description": "The directory name of the language. Should without leading or trailing slash."
                },
                "partials": {
                    "type": "string",
                    "pattern": "^[a-zA-Z0-9]+(\/[a-zA-Z0-9]+)?$",
                    "default": "partials",
                    "description": "The partials directory name. Should without leading or trailing slash. Directory path inside the theme folder: themes/<theme_name>/<partials>"
                },
                "assets": {
                    "type": "string",
                    "pattern": "^[a-zA-Z0-9]+(\/[a-zA-Z0-9]+)?$",
                    "description": "The directory name of the assets. Should without leading or trailing slash. This will be publicly accessible  via /themes/<assets>/..."
                }
            }
        },
        "templates": {
            "type": "object",
            "description": "The templates of the theme. The file extension should be .hbs. Additional names can be added and will be pointed as include template files using {{> template_name}}.",
            "additionalProperties": true,
            "patternProperties": {
                "^[a-zA-Z0-9_-]+$": {
                    "type": "string",
                    "description": "The template file name. Should be lowercase and without leading or trailing dash.",
                    "$ref": "#/definitions/template_file"
                }
            },
            "properties": {
                "layout": {
                    "type": "string",
                    "description": "The template name for layout.",
                    "default": "main",
                    "$ref": "#/definitions/template_file"
                },
                "error": {
                    "type": "string",
                    "description": "The template name for internal error page.",
                    "default": "error",
                    "$ref": "#/definitions/template_file"
                },
                "not_found": {
                    "type": "string",
                    "description": "The template name for 404 error page.",
                    "default": "404",
                    "$ref": "#/definitions/template_file"
                }
            }
        }
    }
}
